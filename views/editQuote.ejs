<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Quote</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header bg-warning">
                <h2>Edit Quote</h2>
            </div>
            <div class="card-body">
                <form method="POST" action="/quote/edit">
                    <input type="hidden" name="quoteId" value="<%=quoteInfo[0].quoteid%>">
                    
                    <div class="mb-3">
                        <label class="form-label">Quote Text *</label>
                        <textarea class="form-control" name="quoteText" rows="4" required><%=quoteInfo[0].quotetext%></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Author *</label>
                            <select class="form-control" name="authorId" required>
                                <option value="">Select Author</option>
                                <% for(let author of authors) { %>
                                    <option value="<%=author.authorid%>" <%= quoteInfo[0].authorid == author.authorid ? 'selected' : '' %>>
                                        <%=author.firstname%> <%=author.lastname%>
                                    </option>
                                <% } %>
                            </select>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Category *</label>
                            <select class="form-control" name="categoryId" required>
                                <option value="">Select Category</option>
                                <% for(let category of categories) { %>
                                    <option value="<%=category.categoryid%>" <%= quoteInfo[0].categoryid == category.categoryid ? 'selected' : '' %>>
                                        <%=category.categoryname%>
                                    </option>
                                <% } %>
                            </select>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Year</label>
                            <input type="number" class="form-control" name="year" value="<%=quoteInfo[0].year || ''%>">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Likes</label>
                            <input type="number" class="form-control" name="likes" value="<%=quoteInfo[0].likes || 0%>">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-control" name="isApproved">
                                <option value="0" <%= quoteInfo[0].isapproved == false ? 'selected' : '' %>>Pending</option>
                                <option value="1" <%= quoteInfo[0].isapproved == true ? 'selected' : '' %>>Approved</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Context/Source</label>
                        <input type="text" class="form-control" name="context" value="<%=quoteInfo[0].context || ''%>">
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Tags</label>
                        <input type="text" class="form-control" name="tags" value="<%=quoteInfo[0].tags || ''%>">
                    </div>
                    
                    <button type="submit" class="btn btn-primary">Update Quote</button>
                    <a href="/quotes" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>