<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Author List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header bg-info text-white">
                <h2>Author List</h2>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Actions</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Date of Birth</th>
                            <th>Nationality</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (let i=0; i < authors.length; i++) { %>
                        <tr>
                            <td>
                                <a href="/author/edit?authorId=<%=authors[i].authorid%>" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/author/delete?authorId=<%=authors[i].authorid%>" 
                                   class="btn btn-sm btn-danger" 
                                   onclick="return confirm('Are you sure?')">Delete</a>
                            </td>
                            <td><%=authors[i].firstname%></td>
                            <td><%=authors[i].lastname%></td>
                            <td><%=authors[i].dob ? authors[i].dob.toISOString().split('T')[0] : 'N/A'%></td>
                            <td><%=authors[i].nationality || 'N/A'%></td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
                <a href="/" class="btn btn-secondary">Back to Home</a>
            </div>
        </div>
    </div>
</body>
</html>