<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quote List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header bg-warning">
                <h2>Quote List</h2>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Actions</th>
                            <th>Quote</th>
                            <th>Author</th>
                            <th>Category</th>
                            <th>Year</th>
                            <th>Likes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (let i=0; i < quotes.length; i++) { %>
                        <tr>
                            <td>
                                <a href="/quote/edit?quoteId=<%=quotes[i].quoteid%>" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/quote/delete?quoteId=<%=quotes[i].quoteid%>" 
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Are you sure?')">Delete</a>
                            </td>
                            <td>"<%=quotes[i].quotetext.substring(0, 100)%><%=quotes[i].quotetext.length > 100 ? '...' : ''%>"</td>
                            <td><%=quotes[i].firstname%> <%=quotes[i].lastname%></td>
                            <td><%=quotes[i].categoryname%></td>
                            <td><%=quotes[i].year || 'N/A'%></td>
                            <td><%=quotes[i].likes || 0%></td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
                <a href="/" class="btn btn-secondary">Back to Home</a>
            </div>
        </div>
    </div>
</body>
</html>